  "pre_install": [
    "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
    "Remove-Item \"$dir\\`$PLUGINSDIR\" -Recurse",
    "$appdata = \"$env:APPDATA\\steamachievementnotifierv1.9\"",
    "if (-not (Test-Path $persist_dir)) { New-Item $persist_dir -ItemType Directory | Out-Null }",
    "if (Test-Path $appdata) {",
    "  if (-not (Get-Item $appdata).LinkType) {",
    "    Move-Item $appdata \"$persist_dir\\appdata\" -Force",
    "  }",
    "} elseif (-not (Test-Path \"$persist_dir\\appdata\")) {",
    "  New-Item \"$persist_dir\\appdata\" -ItemType Directory | Out-Null",
    "}",
    "New-Item $appdata -ItemType Junction -Target \"$persist_dir\\appdata\" -Force | Out-Null"
  ],
  "pre_uninstall": [
    "$appdata = \"$env:APPDATA\\steamachievementnotifierv1.9\"",
    "if ((Test-Path $appdata) -and (Get-Item $appdata).LinkType) {",
    "  Remove-Item $appdata -Force",
    "}"
  ],
